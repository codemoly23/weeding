# ===========================================
# Ceremoney Environment Variables
# Copy this file to .env and fill in values
# ===========================================

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/ceremoney?schema=public"
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=ceremoney
DATABASE_PASSWORD=your_password_here
DATABASE_NAME=ceremoney

# Authentication (NextAuth.js / Auth.js)
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL=http://localhost:3000

# Google OAuth
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Stripe (Global Payments + Subscriptions)
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Stripe Subscription Price IDs
STRIPE_PRICE_PREMIUM=""
STRIPE_PRICE_ELITE=""
STRIPE_PRICE_VENDOR=""
STRIPE_PRICE_WHITE_LABEL=""

# Swish (Swedish Mobile Payments)
SWISH_MERCHANT_ID=""
SWISH_CERTIFICATE=""
SWISH_CALLBACK_URL=""

# Klarna (BNPL)
KLARNA_USERNAME=""
KLARNA_PASSWORD=""
KLARNA_API_URL=""

# AWS S3 (File Storage)
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="eu-north-1"
AWS_S3_BUCKET=""
AWS_CLOUDFRONT_URL=""

# Email (SendGrid or AWS SES)
SENDGRID_API_KEY=""
FROM_EMAIL="Ceremoney <noreply@ceremoney.com>"
SUPPORT_EMAIL="support@ceremoney.com>"

# SMS (46elks - Swedish sender ID)
FORTYSIXELKS_API_USERNAME=""
FORTYSIXELKS_API_PASSWORD=""
SMS_SENDER_ID="Ceremoney"

# Socket.io (Real-time collaboration)
NEXT_PUBLIC_SOCKET_URL=http://localhost:3001
SOCKET_SERVER_PORT=3001

# Redis (Caching + BullMQ job queue)
REDIS_URL="redis://localhost:6379"

# Google Maps (Vendor search, venue locations)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""

# Analytics
NEXT_PUBLIC_GA_ID=""

# Sentry (Error Tracking)
SENTRY_DSN=""

# White-label
WHITE_LABEL_DOMAIN_SUFFIX=".ceremoney.com"
